# ─────────────────────────────────────────────────────────────────────────────
# QLoRA Fine-Tuning Platform — Environment Variables
# Copy this file to .env and populate with your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Hugging Face ─────────────────────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_HOME=/data/huggingface_cache
TRANSFORMERS_CACHE=/data/huggingface_cache/transformers
HF_DATASETS_CACHE=/data/huggingface_cache/datasets

# ── Weights & Biases ─────────────────────────────────────────────────────────
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_ENTITY=your-wandb-entity
WANDB_PROJECT=qlora-finetuning
WANDB_MODE=online          # online | offline | disabled

# ── Training ─────────────────────────────────────────────────────────────────
OUTPUT_DIR=/data/outputs
CHECKPOINTS_DIR=/data/checkpoints
LOGS_DIR=/data/logs

# ── Distributed Training ─────────────────────────────────────────────────────
MASTER_ADDR=localhost
MASTER_PORT=29500
NCCL_DEBUG=INFO
NCCL_IB_DISABLE=0

# ── Inference / Serving ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
MAX_BATCH_SIZE=32
MAX_SEQUENCE_LENGTH=4096

# ── vLLM ─────────────────────────────────────────────────────────────────────
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.90

# ── Database / Storage ───────────────────────────────────────────────────────
S3_BUCKET=your-model-bucket
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json            # json | text

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development    # development | staging | production
DEBUG=false
